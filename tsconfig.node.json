{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "allowJs": false,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vite/**/*.ts", "scripts/**/*.ts"]
}
